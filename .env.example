# .env.example — Oracle Garden
#
# Copy to .env and fill in real values. Real .env is gitignored.
# Variables here are the ones STEPS.md Phase 1 calls for; later phases
# may add more (e.g., SESSION_COOKIE_NAME override in Phase 8/9).

# --- Database -----------------------------------------------------------------
# Local dev (postgres in docker compose, host port 5432):
DATABASE_URL=postgres://oracle:oracle@localhost:5432/oracle_garden?sslmode=disable

# --- Anthropic ----------------------------------------------------------------
# Required by Phase 4 (agent runtime). Get one from https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# --- NextAuth / JWT shared secret ---------------------------------------------
# Required by Phase 9 (frontend) and read by the Go backend's JWT middleware.
# Generate with: openssl rand -base64 32
#
# IMPORTANT: treat as a UTF-8 byte string on both Node and Go sides; do NOT
# base64-decode. The JS side passes this directly as the secret to
# `jsonwebtoken.sign/verify`; the Go side does `[]byte(os.Getenv(...))`.
# Mismatched encoding produces silent "invalid signature" errors.
NEXTAUTH_SECRET=

# --- Cross-process routing ----------------------------------------------------
# The frontend's Next.js rewrites and NextAuth `authorize` callback both call
# the Go backend through this URL (server-to-server, absolute).
#   - Local dev (Next on :3000, Go on :8080):     http://localhost:8080
#   - Docker Compose (Phase 17, service name api): http://api:8080
#   - Production VPS:                              the internal URL of the API
INTERNAL_API_URL=http://localhost:8080

# --- Cost protection (CLAUDE.md "Cost Protection") ----------------------------
MAX_RUNS_PER_USER_PER_DAY=50
MAX_COST_USD_PER_USER_PER_DAY=5.00
MIN_SCHEDULE_INTERVAL_SECONDS=300
EXECUTION_KILL_SWITCH_DEFAULT=false

# --- Admin --------------------------------------------------------------------
# Comma-separated emails granted access to /account/admin and admin API routes.
ADMIN_EMAILS=
